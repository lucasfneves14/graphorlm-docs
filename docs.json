{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Graphor Docs",
  "colors": {
    "primary": "#cc6ca7",
    "light": "#cc6ca7",
    "dark": "#6e2f84"
  },
  "appearance": {
    "default": "system",
    "strict": true
  },
  "favicon": "/favicon.png",
  "interaction": {
    "drilldown": false
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Homepage",
          "icon": "globe",
          "href": "https://graphorlm.com"
        },
        {
          "anchor": "Dashboard",
          "icon": "rocket",
          "href": "https://app.graphorlm.com"
        },
        {
          "anchor": "Support",
          "icon": "envelope",
          "href": "mailto:support@graphorlm.com"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "href": "introduction",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "Developers",
            "pages": [
              "api-overview",
              "sdk-overview",
              "mcp-server",
              "skills"
            ]
          },
          {
            "group": "Data Options",
            "pages": [
              "guides/data-ingestion",
              "guides/data-extraction",
              "guides/document-chat"
            ]
          }
        ]
      },
      {
        "tab": "SDK",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "sdk/overview"
            ]
          },
          {
            "group": "Data SDK Options",
            "pages": [
              {
                "group": "Ingestion",
                "pages": [
                  "sdk/sources/upload",
                  "sdk/sources/process",
                  "sdk/sources/list",
                  "sdk/sources/delete",
                  "sdk/sources/list-elements"
                ]
              },
              "sdk/chat",
              "sdk/extract",
              "sdk/prebuilt-rag"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "api-reference/overview",
              "guides/api-tokens"
            ]
          },
          {
            "group": "Data API Options",
            "pages": [
              {
                "group": "Ingestion API",
                "pages": [
                  "api-reference/sources/upload",
                  "api-reference/sources/process",
                  "api-reference/sources/list",
                  "api-reference/sources/delete",
                  "api-reference/sources/list-elements"
                ]
              },
              "api-reference/chat-api",
              "api-reference/extract-api",
              "api-reference/prebuilt-rag-api"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@graphorlm.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Login",
      "href": "https://app.graphorlm.com/login"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/graphorlm"
    },
    "links": [
      {
        "header": "Product",
        "items": [
          {
            "label": "Homepage",
            "href": "https://graphorlm.com"
          },
          {
            "label": "Pricing",
            "href": "https://graphorlm.com/#pricing"
          },
          {
            "label": "Features",
            "href": "https://graphorlm.com/#bento"
          },
          {
            "label": "Login",
            "href": "https://app.graphorlm.com/login"
          }
        ]
      },
      {
        "header": "Legal",
        "items": [
          {
            "label": "Privacy Policy",
            "href": "https://graphorlm.com/privacy-policy"
          },
          {
            "label": "Terms of Use",
            "href": "https://graphorlm.com/terms-of-use"
          }
        ]
      }
    ]
  }
}